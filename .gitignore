# --- PyInstaller build artifacts ---
# The build tree and the final exe are regenerated by build_exe.bat. The exe is
# distributed via GitHub Releases, not committed to the repo.
build/
dist/

# PyInstaller generates a .spec on every build. build_exe.bat passes all options
# on the command line and redirects the spec to %TEMP% (--specpath), so it never
# lands here. This rule stays as a safety net in case it's ever run without that.
*.spec

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# --- Editor / OS ---
.vscode/
.idea/
Thumbs.db
Desktop.ini
*~

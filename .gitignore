# --- PyInstaller build artifacts ---
# Intermediate build tree and the final exe are regenerated by build_exe.bat.
build/

# PyInstaller writes a .spec file on every build. build_exe.bat passes all
# options on the command line, so the .spec is derived, not the source of truth.
*.spec

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# --- Editor / OS ---
.vscode/
.idea/
Thumbs.db
Desktop.ini
*~
